r\n            <h4 class=\"font-weight-light mb-1 mt-3\">Fax Number</h4>\r\n            <p>(632) 85261029</p>\r\n            <h4 class=\"font-weight-light mb-1\">Telefax Number</h4>\r\n            <p>(632) 53101319</p>\r\n            <h4 class=\"font-weight-light mb-1\">Veritas Hotline</h4>\r\n            <p class=\"mb-0\">0917-511-1372</p>\r\n            <p>0947-996-0107</p>\r\n            <h4 class=\"font-weight-light mb-1\">E-mail Address</h4>\r\n            <p class=\"mb-0\"><a class=\"vmc-text-primary-2\" href=\"mailto:vmcgroup@veritas.com.ph\">vmcgroup@veritas.com.ph</a></p>\r\n            <p class=\"mb-0\"><a class=\"vmc-text-primary-2\" href=\"mailto:veritas_mc@pldtdsl.net\">veritas_mc@pldtdsl.net</a></p>\r\n          </div>\r\n          <div class=\"col-md-6\">\r\n            <h4 class=\"font-weight-light mb-1\">Send us feedback :</h4>\r\n            <form @submit.prevent=\"sendFeedback\">\r\n              <div class=\"form-group\" :class=\"{invalid : fullNameValid === 'invalid'}\">\r\n                <label for=\"Name\">Name : <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <input type=\"text\" class=\"form-control\" id=\"Name\" placeholder=\"\" required\r\n                       v-model.trim=\"fullName\" @blur=\"validateInput\">\r\n                <small v-if=\"fullNameValid === 'invalid'\">Please enter a name!</small>\r\n              </div>\r\n              <div class=\"form-group\" :class=\"{invalid : fullNameValid === 'invalid'}\">\r\n                <label for=\"ContactNumber\">Contact Number : <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <input type=\"text\" class=\"form-control\" id=\"ContactNumber\" placeholder=\"\" required\r\n                       v-model.trim=\"contactNumber\" @blur=\"validateInput\">\r\n                <small v-if=\"contactNumberValid === 'invalid'\">Please enter a valid contact number!</small>\r\n              </div>\r\n              <div class=\"form-group\" :class=\"{invalid : fullNameValid === 'invalid'}\">\r\n                <label for=\"Email\">Email Address : <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <input type=\"email\" class=\"form-control\" id=\"Email\" placeholder=\"\" required\r\n                       v-model.trim=\"emailAddress\" @blur=\"validateInput\">\r\n                <small v-if=\"emailAddressValid === 'invalid'\">Please enter a valid email address!</small>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label for=\"Subject\">Subject : <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <input type=\"text\" class=\"form-control\" id=\"Subject\" placeholder=\"\" required\r\n                       v-model=\"emailSubject\">\r\n                <small>Please enter a subject!</small>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label for=\"Message\">Message : <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <textarea class=\"form-control\" id=\"Message\" rows=\"6\" required\r\n                          v-model=\"emailMessage\"></textarea>\r\n                <small>Please enter a message!</small>\r\n              </div>\r\n              <button type=\"submit\" class=\"btn vmc-btn-circle vmc-btn-prime-2 px-5\">SEND</button>\r\n            </form>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ContactUs\",\r\n  data() {\r\n    return {\r\n      fullName      : '',\r\n      contactNumber : '',\r\n      emailAddress  : '',\r\n      emailSubject  : '',\r\n      emailMessage  : '',\r\n\r\n      fullNameValid      : 'pending',\r\n      contactNumberValid : 'pending',\r\n      emailAddressValid  : 'pending',\r\n      emailSubjectValid  : 'pending',\r\n      emailMessageValid  : 'pending',\r\n    };\r\n  },\r\n  methods: {\r\n    sendFeedback() {\r\n      console.log('Full Name: '+this.fullName.trim());\r\n      this.fullName = '';\r\n      console.log('Contact Number: '+this.contactNumber.trim());\r\n      this.contactNumber = '';\r\n      console.log('Email: '+this.emailAddress.trim());\r\n      this.emailAddress = '';\r\n      console.log('Subject: '+this.emailSubject);\r\n      this.emailSubject = '';\r\n      console.log('Message: '+this.emailMessage);\r\n      this.emailMessage = '';\r\n    },\r\n    validateInput() {\r\n      if (this.fullName === ''){\r\n        this.fullNameValid = 'invalid'\r\n      } else {\r\n        this.fullNameValid = 'valid'\r\n      }\r\n      if (this.contactNumber === ''){\r\n        this.contactNumberValid = 'invalid'\r\n      } else {\r\n        this.contactNumberValid = 'valid'\r\n      }\r\n      if (this.emailAddress === ''){\r\n        this.emailAddressValid = 'invalid'\r\n      } else {\r\n        this.emailAddressValid = 'valid'\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.invalid .form-control {\r\n  border-color : var(--vmc-danger-5);\r\n}\r\n.invalid small {\r\n  color: var(--vmc-danger-5);\r\n}\r\n</style>"],"sourceRoot":"src/components/contact-us"}]}