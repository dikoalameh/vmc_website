ets/testphotos/bg.jpg\" id=\"bg\" alt=\"\">-->\r\n<!--      <img src=\"../assets/testphotos/moon.png\" id=\"moon\" alt=\"\">-->\r\n<!--      <img src=\"../assets/testphotos/mountain.png\" id=\"mountain\" alt=\"\">-->\r\n<!--      <img src=\"../assets/testphotos/road.png\" id=\"road\" alt=\"\">-->\r\n      <h1 id=\"text\" class=\"font-weight-light\">{{ pageTitleName }}</h1>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PageHeading\",\r\n  props: ['pageTitleName','imageLink'],\r\n  data() {\r\n    return {\r\n      'pageBackground': require(`@/assets/about/30Years.jpg`),\r\n    }\r\n  },\r\n  mounted() {\r\n    // todo this is for moving images na patong patong\r\n    let pageBg = document.getElementById('PageBackground');\r\n    // let bg = document.getElementById('bg');\r\n    // let moon = document.getElementById('moon');\r\n    // let mountain = document.getElementById('mountain');\r\n    // let road = document.getElementById('road');\r\n    // let text = document.getElementById('text');\r\n\r\n    window.addEventListener('scroll', function(){\r\n      const value = window.scrollY;\r\n\r\n      pageBg.style.top = value * 0.5 + 'px';\r\n      // bg.style.top = value * 0.5 + 'px';\r\n      // moon.style.left = -value * 0.5 + 'px';\r\n      // mountain.style.top = -value * 0.15 + 'px';\r\n      // road.style.top = value * 0.15 + 'px';\r\n      // text.style.top = value + 'px';\r\n    })\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* todo this is for parallax with magkakapatong na images */\r\n  section {\r\n    position: relative;\r\n    width: 100%;\r\n    height: 550px;\r\n    overflow: hidden;\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n  }\r\n  section:before {\r\n    content: '';\r\n    position: absolute;\r\n    bottom: 0;\r\n    width: 100%;\r\n    height: 100px;\r\n    background: linear-gradient(to top, var(--vmc-primary-5), transparent);\r\n    z-index: 10;\r\n  }\r\n  section:after {\r\n    content: '';\r\n    position: absolute;\r\n    top: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    background: var(--vmc-primary-5);\r\n    mix-blend-mode: color;\r\n    z-index: 10;\r\n  }\r\n  section img {\r\n    position: absolute;\r\n    top: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    object-fit: cover;\r\n    pointer-events: none;\r\n  }\r\n  #text {\r\n    position: relative;\r\n    color: white;\r\n    font-size: 5rem;\r\n    z-index: 1;\r\n    text-shadow: 2px 2px 5px var(--vmc-dark-10);\r\n  }\r\n  #road {\r\n    z-index: 2;\r\n  }\r\n  @media (min-width: 576px) {\r\n    #text {\r\n      margin-top: 85px;\r\n    }\r\n  }\r\n\r\n  @media (min-width: 768px) {\r\n    #text {\r\n      margin-top: 85px;\r\n    }\r\n  }\r\n\r\n  @media (min-width: 992px) {\r\n    #text {\r\n      margin-top: 105px;\r\n    }\r\n  }\r\n\r\n  @media (min-width: 1200px) {\r\n    #text {\r\n      margin-top: 105px;\r\n    }\r\n  }\r\n</style>"],"sourceRoot":"src/components"}]}