{"remainingRequest":"C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\src\\components\\contact-us\\ContactUsNew.vue?vue&type=style&index=0&id=57bd8d74&scoped=true&lang=css&","dependencies":[{"path":"C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\src\\components\\contact-us\\ContactUsNew.vue","mtime":1625080546101},{"path":"C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\node_modules\\css-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":499162500000},{"path":"C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\node_modules\\postcss-loader\\src\\index.js","mtime":499162500000},{"path":"C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\user\\Desktop\\VERITAS\\veritas_website\\vmc_website\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["ContactUsNew.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAsLA;AACA;AACA;AACA;AACA;;;;;;;;;AASA;AACA;AACA;AACA;AACA;AACA;AACA","file":"ContactUsNew.vue","sourceRoot":"src/components/contact-us","sourcesContent":["<template>\r\n  <div class=\"contact\">\r\n    <div class=\"container-fluid vmc-py-big\">\r\n      <div class=\"container\">\r\n        <div class=\"row\">\r\n          <div class=\"col-12 text-center\">\r\n            <h2 class=\"h1 vmc-text-primary vmc-heading\">\r\n              Connect To Us\r\n            </h2>\r\n          </div>\r\n          <div class=\"col-md-6\">\r\n            <h4 class=\"font-weight-light mb-1\">Address</h4>\r\n            <p>15 Floor, MARC2000 Tower 1973 Taft Ave., Malate, Manila Philippines 1004</p>\r\n            <a href=\"https://goo.gl/maps/PWLBE4UL9ECrVMW37\" target=\"_blank\" class=\"btn vmc-btn-circle vmc-btn-prime-2 px-3 mx-1\">\r\n              Google Maps\r\n            </a>\r\n            <a href=\"https://www.waze.com/en/live-map/directions/philippines/metro-manila/malate/veritas-maritime-corporation?utm_campaign=waze_website&utm_medium=website_menu&utm_source=waze_website&to=place.ChIJt48LqIHJlzMRYCKYCZFTix4\" target=\"_blank\" class=\"btn vmc-btn-circle vmc-btn-prime-2 px-4 mx-1\">\r\n              Waze Map\r\n            </a>\r\n            <h4 class=\"font-weight-light mb-1 mt-3\">Telephone Number</h4>\r\n            <table>\r\n              <tr>\r\n                <th>PCC Division</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 85362775</td>\r\n              </tr>\r\n              <tr>\r\n                <th>BULK Division</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 85268041</td>\r\n              </tr>\r\n              <tr>\r\n                <th>DOCS Division</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 85241691</td>\r\n              </tr>\r\n              <tr>\r\n                <th>Training Division</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 53100317</td>\r\n              </tr>\r\n              <tr>\r\n                <th>Accounting Dept</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 85243661</td>\r\n              </tr>\r\n              <tr>\r\n                <th></th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 85362757</td>\r\n              </tr>\r\n              <tr>\r\n                <th>Exec. Offices</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 53101319</td>\r\n              </tr>\r\n              <tr>\r\n                <th>Admin Dept</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>(632) 85261034</td>\r\n              </tr>\r\n            </table>\r\n            <h4 class=\"font-weight-light mb-1 mt-3\">Fax Number</h4>\r\n            <p>(632) 85261029</p>\r\n            <h4 class=\"font-weight-light mb-1\">Veritas Hotline</h4>\r\n            <p class=\"mb-0\">0917-511-1372</p>\r\n            <p>0947-996-0107</p>\r\n          </div>\r\n          <div class=\"col-md-6\">\r\n            <h4 class=\"font-weight-light mb-1\">E-mail Address</h4>\r\n            <p class=\"mb-0\"><a class=\"vmc-text-primary-2\" href=\"mailto:vmcgroup@veritas.com.ph\">vmcgroup@veritas.com.ph</a></p>\r\n            <p class=\"\"><a class=\"vmc-text-primary-2\" href=\"mailto:vmccomm@veritas.com.ph\">vmccomm@veritas.com.ph</a></p>\r\n\r\n            <h4 class=\"font-weight-light mb-1\">Facebook Page</h4>\r\n            <table>\r\n              <tr>\r\n                <th>Veritas Crew</th>\r\n                <th class=\"px-2\"> : </th>\r\n                <td>\r\n                  <a href=\"https://www.facebook.com/veritas.maritime.587\"\r\n                     target=\"_blank\" class=\"vmc-text-primary-2\">\r\n                    https://www.facebook.com/veritas.maritime.587</a>\r\n                </td>\r\n              </tr>\r\n            </table>\r\n\r\n            <h4 class=\"font-weight-light mb-1 mt-3\">Send us comments / feedback :</h4>\r\n            <form @submit.prevent=\"sendFeedback\" ref=\"sendFeedbackForm\">\r\n              <div class=\"form-group mb-1\">\r\n                <label for=\"FullName\" class=\"mb-0\">Full Name: <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <input class=\"form-control\" id=\"FullName\"\r\n                       required aria-required=\"true\">\r\n                <div class=\"error-message small\">\r\n                  <span>Test Error</span>\r\n                </div>\r\n              </div>\r\n              <div class=\"form-group mb-1\">\r\n                <label for=\"EmailAddress\" class=\"mb-0\">Email Address: <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <input class=\"form-control\" id=\"EmailAddress\"\r\n                       required aria-required=\"true\">\r\n                <div class=\"error-message small\">\r\n                  <span>Test Error</span>\r\n                </div>\r\n              </div>\r\n              <div class=\"form-group mb-1\">\r\n                <label for=\"ContactNumber\" class=\"mb-0\">Contact Number: <sup class=\"vmc-text-danger\">*</sup></label>\r\n                <input class=\"form-control\" id=\"ContactNumber\"\r\n                       required aria-required=\"true\">\r\n                <div class=\"error-message small\">\r\n                  <span>Test Error</span>\r\n                </div>\r\n              </div>\r\n              <div class=\"form-group mb-1\">\r\n                <label for=\"Message\" class=\"mb-0\">\r\n                  Feedback / Comments: <sup class=\"vmc-text-danger\">*</sup>\r\n                </label>\r\n                <textarea name=\"Message\" id=\"Message\" class=\"form-control\" rows=\"4\" required>\r\n                </textarea>\r\n                <div class=\"error-message small\">\r\n                  <span>Test Error</span>\r\n                </div>\r\n              </div>\r\n              <button type=\"submit\" class=\"btn vmc-btn-circle vmc-btn-prime-2 px-5\">SEND</button>\r\n            </form>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"container-fluid\">\r\n      <div class=\"row no-gutters\">\r\n        <div class=\"col-md-12 mb-0 pb-0\" id=\"GoogleMapContainer\">\r\n          <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3861.5044557253113!2d120.9890083153022!3d14.570307181723464!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3397c981a80b8fb7%3A0x1e8b539109982260!2sVeritas%20Maritime%20Corporation!5e0!3m2!1sen!2sph!4v1620362498790!5m2!1sen!2sph\" width=\"100%\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\"></iframe>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Swal from 'sweetalert2';\r\n\r\nexport default {\r\n  name: 'ContactUsNew',\r\n  data() {\r\n    return {\r\n      fullName      : '',\r\n      contactNumber : '',\r\n      emailMessage  : '',\r\n    };\r\n  },\r\n  methods: {\r\n    sendFeedback() {\r\n      Swal.fire({\r\n        title: 'Are you sure?',\r\n        text: 'This will directly contact Veritas!',\r\n        icon: 'question',\r\n        showCancelButton: true,\r\n        confirmButtonText: 'Yes, send it!',\r\n        confirmButtonColor: '#84a7c6',\r\n        cancelButtonText: 'Cancel',\r\n      }).then((result) => {\r\n        if (result.value) {\r\n          window.location.href =\r\n              `mailto:shantycajulao@gmail.com?subject=Name: ${this.fullName} — Contact Number: ${this.contactNumber}&body=Message: %0D%0A${this.emailMessage}`\r\n          Swal.fire(\r\n              'Email opened',\r\n              'Opened your email to validate your email and message',\r\n              'success',\r\n          )\r\n          this.fullName = ''\r\n          this.contactNumber = ''\r\n          this.emailMessage = ''\r\n          this.$nextTick(() => { this.$v.$reset(); });\r\n        }\r\n      })\r\n    },\r\n\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.error-message *{\r\n  color: var(--vmc-danger-5);\r\n  opacity: .5;\r\n  font-weight: bold;\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n.swal2-confirm .swal2-styled {\r\n  border-radius: 100px;\r\n  background-color: var(--vmc-primary-3);\r\n}\r\n#GoogleMapContainer {\r\n  line-height: 0;\r\n}\r\n</style>\r\n"]}]}